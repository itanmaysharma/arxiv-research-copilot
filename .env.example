APP_NAME=arxiv-paper-curator-manual
APP_ENV=dev
APP_PORT=8000

POSTGRES_DB=arxiv_curator
POSTGRES_USER=arxiv
POSTGRES_PASSWORD=arxivpass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://arxiv:arxivpass@postgres:5432/arxiv_curator

OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin

AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin

OLLAMA_BASE_URL=http://ollama:11434
REDIS_URL=redis://redis:6379/0

# Optional for real semantic embeddings (Part parity P0-2)
JINA_API_KEY=
JINA_BASE_URL=https://api.jina.ai/v1/embeddings
JINA_EMBEDDING_MODEL=jina-embeddings-v3
EMBEDDING_DIMENSIONS=1024

# Optional tracing config (Part parity P0-3)
TRACING_ENABLED=true
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Optional telegram bot (Part parity P3-C3)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_API_BASE_URL=http://127.0.0.1:8000
TELEGRAM_POLL_INTERVAL_SECONDS=2.0
